# secrets.toml.example
#
# Copy this file to assets/settings/secrets.toml and fill in real values.
# secrets.toml is excluded from version control (.gitignore).
# Restrict file permissions to the service user only:
#   chmod 600 assets/settings/secrets.toml
#
# NEVER commit real credentials to the repository.

# Adafruit IO MQTT broker credentials
ADAFRUIT_IO_USERNAME = "your_aio_username"
ADAFRUIT_IO_KEY      = "aio_xxxxxxxxxxxxxxxxxxxx"
ADAFRUIT_IO_FEED     = "your_feed_name"

# Shared token that must prefix every MQTT command payload for authentication.
# Example payload: "ZENG open 3"
MQTT_command_token = "ZENG"

# Flink backend
FLINK_URL     = "https://your-flink-instance.example.com/api"
FLINK_API_KEY = "your_flink_api_key"

# NFC / DESFire settings
[NFC]
masterkey = "ZE_MasterKey_Current"  # 16-byte UTF-8 string
app_id    = "ZEK"                   # 3-byte application ID string
sys_id    = "ZE1"                   # 3-byte system ID string

# Previous master keys used on deployed cards (oldest first).
# Used only by nfc.format() to recover cards that were personalised with
# an older key.  Remove entries once all cards using that key are gone.
old_keys = [
    "ZE_MasterKey2025",
]
